# MongoDB connection (Railway: set on the Next.js service; often reference the Mongo plugin’s MONGO_URL).
# Used by prisma.config.ts (CLI: db push) and by prisma/schema.prisma datasource (Prisma 6 still requires url there).
# After schema changes: pnpm exec prisma db push && pnpm exec prisma generate
DATABASE_URL="mongodb+srv://USER:PASSWORD@HOST/DATABASE?retryWrites=true&w=majority"
